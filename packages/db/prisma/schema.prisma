// ============================================================
// KSCSYSTEM — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth & Users ---

enum UserRole {
  superadmin
  org_admin
  member
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  role           UserRole  @default(member)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  passwordHash   String?
  supabaseId     String?   @unique
  avatarUrl      String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  checklistProgress   ChecklistProgress[]
  documents           Document[]
  incidents           Incident[]
  quizSessions        QuizSession[]
  passwordResetTokens PasswordResetToken[]

  @@index([organizationId])
  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// --- Organizations ---

enum OrganizationType {
  essential   // podmioty kluczowe
  important   // podmioty ważne
  unknown
}

model Organization {
  id          String           @id @default(cuid())
  name        String
  nip         String?          @unique
  sector      String?
  size        String?          // micro, small, medium, large
  type        OrganizationType @default(unknown)
  website     String?
  phone       String?
  address     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  users              User[]
  checklistProgress  ChecklistProgress[]
  documents          Document[]
  incidents          Incident[]
  subscription       Subscription?
  payments           Payment[]
  leads              Lead[]

  @@index([nip])
}

// --- Quiz ---

model QuizQuestion {
  id          String           @id @default(cuid())
  code        String           @unique
  text        String
  description String?
  type        String           @default("single") // single, multiple, scale
  category    String?
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  options     QuizOption[]
  answers     QuizAnswer[]
}

model QuizOption {
  id          String       @id @default(cuid())
  questionId  String
  question    QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text        String
  value       String
  description String?
  weight      Float        @default(0)
  sortOrder   Int          @default(0)

  answers    QuizAnswer[]

  @@index([questionId])
}

model QuizSession {
  id              String       @id @default(cuid())
  userId          String?
  user            User?        @relation(fields: [userId], references: [id])
  leadId          String?
  lead            Lead?        @relation(fields: [leadId], references: [id])
  score           Float?
  classification  String?      // essential, important, not_applicable
  completedAt     DateTime?
  createdAt       DateTime     @default(now())

  answers         QuizAnswer[]

  @@index([userId])
  @@index([leadId])
}

model QuizAnswer {
  id         String       @id @default(cuid())
  sessionId  String
  session    QuizSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id])
  optionId   String?
  option     QuizOption?  @relation(fields: [optionId], references: [id])
  textValue  String?

  @@index([sessionId])
  @@index([questionId])
}

model ScoringRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  condition   Json     // { field, operator, value }
  score       Float
  category    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Leads ---

model Lead {
  id             String        @id @default(cuid())
  email          String
  name           String?
  company        String?
  phone          String?
  nip            String?
  source         String?       @default("quiz") // quiz, contact, manual
  score          Float?
  classification String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  notes          String?
  isConverted    Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  quizSessions   QuizSession[]

  @@index([email])
  @@index([organizationId])
}

// --- Checklist ---

model ChecklistItem {
  id            String   @id @default(cuid())
  code          String   @unique
  category      String
  title         String
  description   String
  priority      Int      @default(0)
  isActive      Boolean  @default(true)
  appliesToType String   @default("all") // all, essential, important
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  progress      ChecklistProgress[]
}

enum ChecklistStatus {
  todo
  in_progress
  done
  not_applicable
}

model ChecklistProgress {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemId         String
  item           ChecklistItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  status         ChecklistStatus @default(todo)
  completedAt    DateTime?
  completedById  String?
  completedBy    User?           @relation(fields: [completedById], references: [id])
  note           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([organizationId, itemId])
  @@index([organizationId])
  @@index([itemId])
}

// --- Documents ---

enum DocumentStatus {
  draft
  published
  archived
}

model DocumentTemplate {
  id          String         @id @default(cuid())
  name        String
  type        String         // policy, procedure, report, plan
  description String?
  content     String
  version     Int            @default(1)
  status      DocumentStatus @default(draft)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  documents   Document[]
}

model Document {
  id             String            @id @default(cuid())
  templateId     String?
  template       DocumentTemplate? @relation(fields: [templateId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User              @relation(fields: [createdById], references: [id])
  name           String
  type           String
  content        String?
  version        Int               @default(1)
  status         DocumentStatus    @default(draft)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([templateId])
}

// --- Incidents ---

enum IncidentSeverity {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  open
  investigating
  resolved
  closed
}

model Incident {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reportedById   String
  reportedBy     User             @relation(fields: [reportedById], references: [id])
  title          String
  description    String
  severity       IncidentSeverity @default(medium)
  status         IncidentStatus   @default(open)
  resolvedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId])
}

// --- Plans & Subscriptions ---

model Plan {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  description   String?
  priceMonthly  Float
  priceYearly   Float?
  features      Json?    // ["feature1", "feature2"]
  maxUsers      Int      @default(1)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

enum SubscriptionStatus {
  trial
  active
  cancelled
  expired
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String             @unique
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId         String
  plan           Plan               @relation(fields: [planId], references: [id])
  status         SubscriptionStatus @default(trial)
  trialEndsAt    DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  payments       Payment[]

  @@index([planId])
}

// --- Payments ---

enum PaymentStatus {
  new
  pending
  confirmed
  rejected
  abandoned
  expired
  error
}

model Payment {
  id              String        @id @default(cuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  paynowPaymentId String?       @unique
  externalId      String        @unique
  amount          Int           // in grosze
  currency        String        @default("PLN")
  description     String?
  status          PaymentStatus @default(new)
  planCode        String?
  billingPeriod   String?       // monthly, yearly
  paynowData      Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
  @@index([paynowPaymentId])
  @@index([externalId])
}

// --- CMS ---

model CmsContent {
  id          String   @id @default(cuid())
  key         String   @unique
  section     String
  title       String?
  content     String?
  jsonData    Json?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([section])
  @@index([key])
}
