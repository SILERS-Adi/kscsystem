// ============================================================
// KSCSYSTEM — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth & Users ---

enum UserRole {
  superadmin
  org_admin
  member
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  role           UserRole  @default(member)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  passwordHash   String?
  supabaseId     String?   @unique
  avatarUrl      String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  checklistProgress   ChecklistProgress[]
  documents           Document[]
  incidents           Incident[]
  quizSessions        QuizSession[]
  passwordResetTokens PasswordResetToken[]
  auditSessions       AuditSession[]

  @@index([organizationId])
  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// --- Organizations ---

enum OrganizationType {
  essential   // podmioty kluczowe
  important   // podmioty ważne
  unknown
}

model Organization {
  id          String           @id @default(cuid())
  name        String
  nip         String?          @unique
  sector      String?
  size        String?          // micro, small, medium, large
  type        OrganizationType @default(unknown)
  website     String?
  phone       String?
  address     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  users              User[]
  checklistProgress  ChecklistProgress[]
  documents          Document[]
  incidents          Incident[]
  subscription       Subscription?
  payments           Payment[]
  leads              Lead[]
  auditSessions      AuditSession[]
  remediationActions RemediationAction[]

  @@index([nip])
}

// --- Quiz ---

model QuizQuestion {
  id          String           @id @default(cuid())
  code        String           @unique
  text        String
  description String?
  type        String           @default("single") // single, multiple, scale
  category    String?
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  options     QuizOption[]
  answers     QuizAnswer[]
}

model QuizOption {
  id          String       @id @default(cuid())
  questionId  String
  question    QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text        String
  value       String
  description String?
  weight      Float        @default(0)
  sortOrder   Int          @default(0)

  answers    QuizAnswer[]

  @@index([questionId])
}

model QuizSession {
  id              String       @id @default(cuid())
  userId          String?
  user            User?        @relation(fields: [userId], references: [id])
  leadId          String?
  lead            Lead?        @relation(fields: [leadId], references: [id])
  score           Float?
  classification  String?      // essential, important, not_applicable
  completedAt     DateTime?
  createdAt       DateTime     @default(now())

  answers         QuizAnswer[]

  @@index([userId])
  @@index([leadId])
}

model QuizAnswer {
  id         String       @id @default(cuid())
  sessionId  String
  session    QuizSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id])
  optionId   String?
  option     QuizOption?  @relation(fields: [optionId], references: [id])
  textValue  String?

  @@index([sessionId])
  @@index([questionId])
}

model ScoringRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  condition   Json     // { field, operator, value }
  score       Float
  category    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Leads ---

model Lead {
  id             String        @id @default(cuid())
  email          String
  name           String?
  company        String?
  phone          String?
  nip            String?
  source         String?       @default("quiz") // quiz, contact, manual
  score          Float?
  classification String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  notes          String?
  isConverted    Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  quizSessions   QuizSession[]

  @@index([email])
  @@index([organizationId])
}

// --- Analytics ---

model PageView {
  id        String   @id @default(cuid())
  path      String                        // np. "/", "/quiz", "/wynik"
  referrer  String?
  source    String?  @default("landing")  // landing, web
  sessionId String?                        // anonimowy identyfikator wizyty (cookie)
  userAgent String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([sessionId])
}

// --- Checklist ---

model ChecklistItem {
  id            String   @id @default(cuid())
  code          String   @unique
  category      String
  title         String
  description   String
  priority      Int      @default(0)
  isActive      Boolean  @default(true)
  appliesToType String   @default("all") // all, essential, important
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  progress      ChecklistProgress[]
}

enum ChecklistStatus {
  todo            // nie mamy
  in_progress     // częściowo
  done            // mamy
  not_applicable  // nie dotyczy
}

model ChecklistProgress {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemId          String
  item            ChecklistItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  status          ChecklistStatus @default(todo)
  completedAt     DateTime?
  completedById   String?
  completedBy     User?           @relation(fields: [completedById], references: [id])
  note            String?
  evidenceUrl     String?         // link do dowodu / dokumentu
  responsibleName String?         // osoba odpowiedzialna
  dueDate         DateTime?       // termin realizacji
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([organizationId, itemId])
  @@index([organizationId])
  @@index([itemId])
}

// ============================================================
// --- Audyt Startowy / Gap Analysis (moduł konsultingowy) ---
// ============================================================

enum AuditAnswerStatus {
  yes             // posiada
  partial         // wdrożone częściowo
  no              // nie posiada
  not_applicable  // nie dotyczy
}

enum AuditSessionStatus {
  draft
  in_progress
  completed
}

enum FindingSeverity {
  critical
  high
  medium
  low
}

enum MaturityLevel {
  initial       // Początkowy
  basic         // Podstawowy
  intermediate  // Średni
  advanced      // Zaawansowany
  mature        // Dojrzały
}

// Szablon audytu (wersjonowany zestaw sekcji i pytań)
model AuditTemplate {
  id          String         @id @default(cuid())
  name        String
  version     Int            @default(1)
  description String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  sections    AuditSection[]
  sessions    AuditSession[]

  @@unique([name, version])
}

model AuditSection {
  id          String          @id @default(cuid())
  templateId  String
  template    AuditTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  code        String          // np. "org_info"
  title       String
  description String?
  sortOrder   Int             @default(0)

  questions   AuditQuestion[]

  @@index([templateId])
}

model AuditQuestion {
  id             String          @id @default(cuid())
  sectionId      String
  section        AuditSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  code           String          // np. "assets_servers"
  text           String
  helpText       String?
  weight         Int             @default(1)              // waga w scoringu dojrzałości
  severity       FindingSeverity @default(medium)         // istotność braku gdy NO
  recommendation String?                                  // domyślne zalecenie gdy NO/PARTIAL
  inputType      String          @default("status")       // status, number, text (np. liczba pracowników)
  sortOrder      Int             @default(0)

  answers        AuditAnswer[]

  @@index([sectionId])
}

// Sesja audytu = przeprowadzony audyt dla organizacji (wersjonowany)
model AuditSession {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateId     String
  template       AuditTemplate       @relation(fields: [templateId], references: [id])
  templateVersion Int                @default(1)          // migawka wersji szablonu
  conductedById  String?
  conductedBy    User?               @relation(fields: [conductedById], references: [id])
  status         AuditSessionStatus  @default(draft)
  maturityScore  Float?                                   // 0-100
  maturityLevel  MaturityLevel?
  note           String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  answers         AuditAnswer[]
  findings        AuditFinding[]
  recommendations AuditRecommendation[]

  @@index([organizationId])
  @@index([createdAt])
}

model AuditAnswer {
  id                String             @id @default(cuid())
  sessionId         String
  session           AuditSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId        String
  question          AuditQuestion      @relation(fields: [questionId], references: [id])
  status            AuditAnswerStatus?                    // null = jeszcze nieodpowiedziane
  valueText         String?                              // dla pytań tekstowych/liczbowych
  note              String?
  responsiblePerson String?
  dueDate           DateTime?
  attachmentUrl     String?
  updatedAt         DateTime           @updatedAt

  @@unique([sessionId, questionId])
  @@index([sessionId])
  @@index([questionId])
}

model AuditFinding {
  id          String          @id @default(cuid())
  sessionId   String
  session     AuditSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId  String?
  severity    FindingSeverity
  title       String
  description String?
  sectionCode String?
  createdAt   DateTime        @default(now())

  recommendations AuditRecommendation[]

  @@index([sessionId])
}

model AuditRecommendation {
  id                String        @id @default(cuid())
  sessionId         String
  session           AuditSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  findingId         String?
  finding           AuditFinding? @relation(fields: [findingId], references: [id], onDelete: SetNull)
  priority          Int           @default(0)
  title             String
  description       String?
  status            String        @default("open") // open, in_progress, done
  responsiblePerson String?
  dueDate           DateTime?
  createdAt         DateTime      @default(now())

  @@index([sessionId])
}

// Trwały rejestr działań naprawczych na poziomie ORGANIZACJI (ponad pojedynczą sesją).
// Zalecenia z audytu "promują się" tutaj; kolejny audyt weryfikuje i zamyka je
// (questionCode łączy ten sam punkt między audytami #N i #N+1).
model RemediationAction {
  id                String           @id @default(cuid())
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  questionCode      String?          // łącznik między audytami (kod pytania)
  sectionCode       String?
  severity          FindingSeverity?
  priority          Int              @default(3)
  title             String
  description       String?
  status            String           @default("open") // open, in_progress, done, deferred, accepted_risk
  responsiblePerson String?
  dueDate           DateTime?
  evidenceUrl       String?
  note              String?
  sourceSessionId   String?          // audyt, który wykrył lukę
  closedSessionId   String?          // audyt, który zweryfikował zamknięcie
  closedAt          DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([organizationId, questionCode])
  @@index([organizationId])
  @@index([status])
}

// --- Documents ---

enum DocumentStatus {
  draft
  published
  archived
}

model DocumentTemplate {
  id          String         @id @default(cuid())
  name        String
  type        String         // policy, procedure, report, plan
  description String?
  content     String
  version     Int            @default(1)
  status      DocumentStatus @default(draft)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  documents   Document[]
}

model Document {
  id             String            @id @default(cuid())
  templateId     String?
  template       DocumentTemplate? @relation(fields: [templateId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User              @relation(fields: [createdById], references: [id])
  name           String
  type           String
  content        String?
  version        Int               @default(1)
  status         DocumentStatus    @default(draft)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([templateId])
}

// --- Incidents ---

enum IncidentSeverity {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  open
  investigating
  resolved
  closed
}

model Incident {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reportedById   String
  reportedBy     User             @relation(fields: [reportedById], references: [id])
  title          String
  description    String
  severity       IncidentSeverity @default(medium)
  status         IncidentStatus   @default(open)
  detectedAt     DateTime?        // moment wykrycia — podstawa terminów KSC 24h/72h
  csirtReportedAt DateTime?       // kiedy zgłoszono do CSIRT (zatrzymuje zegar)
  resolvedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId])
}

// --- Plans & Subscriptions ---

model Plan {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  description   String?
  priceMonthly  Float
  priceYearly   Float?
  features      Json?    // ["feature1", "feature2"]
  maxUsers      Int      @default(1)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

enum SubscriptionStatus {
  trial
  active
  cancelled
  expired
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String             @unique
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId         String
  plan           Plan               @relation(fields: [planId], references: [id])
  status         SubscriptionStatus @default(trial)
  trialEndsAt    DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  payments       Payment[]

  @@index([planId])
}

// --- Payments ---

enum PaymentStatus {
  new
  pending
  confirmed
  rejected
  abandoned
  expired
  error
}

model Payment {
  id              String        @id @default(cuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  paynowPaymentId String?       @unique
  externalId      String        @unique
  amount          Int           // in grosze
  currency        String        @default("PLN")
  description     String?
  status          PaymentStatus @default(new)
  planCode        String?
  billingPeriod   String?       // monthly, yearly
  paynowData      Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
  @@index([paynowPaymentId])
  @@index([externalId])
}

// --- CMS ---

// Proste ustawienia systemowe klucz-wartość (panel admina).
model Setting {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt
}

model CmsContent {
  id          String   @id @default(cuid())
  key         String   @unique
  section     String
  title       String?
  content     String?
  jsonData    Json?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([section])
  @@index([key])
}
